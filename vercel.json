{
  "version": 2,
  "public": false,
  "buildCommand": "python manage.py collectstatic --noinput",
  "outputDirectory": "staticfiles",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python@3.13",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.13"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1",
    "DEBUG": "False"
  }
}
